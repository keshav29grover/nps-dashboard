{
  "rewrites": [
    {
      "source": "/api/nps/:path*",
      "destination": "https://npsnav.in/api/:path*"
    },
    {
      "source": "/api/pb/:path*",
      "destination": "https://nps.purifiedbytes.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
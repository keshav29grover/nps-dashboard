{
  "rewrites": [
    {
      "source": "/proxy/hdfc/:path*",
      "destination": "https://www.hdfcpension.com/:path*"
    },
    {
      "source": "/proxy/nps/:path*",
      "destination": "https://npsnav.in/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
